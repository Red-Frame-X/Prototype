# =========================
# 1. High-Volume Directories (パフォーマンス最適化)
# =========================
# Gitが早期に走査を打ち切れるよう、内部ファイルが膨大なディレクトリを最上部に配置
node_modules/
.idea/
.history/
$RECYCLE.BIN/

# =========================
# 2. Operating System Files
# =========================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux / ChromeOS
*~
.fuse_hidden*
.directory
.Trash-*

# =========================
# 3. Editor & IDE Files
# =========================
# VSCodium / VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
*.iml

# =========================
# 4. Logs (Node.js & aglint)
# =========================
npm-debug.log
yarn-error.log
.pnpm-debug.log
